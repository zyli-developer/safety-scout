{
  "name": "safety-scout-miniprogram",
  "version": "0.3.0",
  "private": true,
  "description": "Safety Scout 工地安全隐患识别小程序",
  "scripts": {
    "build:weapp": "taro build --type weapp",
    "dev:weapp": "taro build --type weapp --watch",
    "build:h5": "taro build --type h5",
    "build:h5:dev": "cross-env TARO_API_BASE_URL=http://localhost:8001 taro build --type h5",
    "dev:h5": "taro build --type h5 --watch",
    "dev:h5:dev": "cross-env TARO_API_BASE_URL=http://localhost:8001 taro build --type h5 --watch",
    "serve:h5": "node scripts/serve-h5.mjs",
    "dev:backend": "nodemon --watch ../backend/app --watch ../backend/scripts --ext py --signal SIGTERM --exec \"node scripts/start-backend.mjs\"",
    "dev:backend:once": "node scripts/start-backend.mjs",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test:e2e:h5": "node tests/e2e/h5-smoke.mjs",
    "test:e2e:h5:responsive": "node tests/e2e/h5-responsive.mjs",
    "test:e2e:h5:photo": "node tests/e2e/h5-photo-flow.mjs",
    "test:e2e:h5:real": "node tests/e2e/h5-real.mjs",
    "test:e2e:h5:desktop:real": "node tests/e2e/h5-desktop.mjs"
  },
  "dependencies": {
    "@tarojs/components": "^4.0.0",
    "@tarojs/helper": "^4.0.0",
    "@tarojs/plugin-framework-react": "^4.0.0",
    "@tarojs/plugin-platform-h5": "^4.0.0",
    "@tarojs/plugin-platform-weapp": "^4.0.0",
    "@tarojs/react": "^4.0.0",
    "@tarojs/runtime": "^4.0.0",
    "@tarojs/shared": "^4.0.0",
    "@tarojs/taro": "^4.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.6.2",
    "@tarojs/cli": "^4.0.0",
    "@tarojs/taro-loader": "^4.0.0",
    "@tarojs/webpack5-runner": "^4.0.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^14.2.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "babel-jest": "^29.7.0",
    "babel-preset-taro": "^4.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "nodemon": "^3.1.14",
    "playwright-core": "^1.60.0",
    "react-refresh": "^0.18.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0"
  }
}
