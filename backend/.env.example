# LLM provider 开关 —— 业务粒度的二选一：claude_cli | doubao
# 默认 claude_cli；provider 内部具体走哪个模型见各自 *_MODEL 字段
LLM_PROVIDER=claude_cli

# Claude CLI provider - 无需 API key（走本地 Claude 登录态）
# 安装：见 https://claude.com/claude-code
# 登录：claude login
CLAUDE_CLI_PATH=claude
# 用全名而非 sonnet alias —— alias 在 Phase 1 实测会路由到 Opus，成本翻倍
# 见 docs/specs/prompt-poc-notes.md § 模型路由观察
CLAUDE_MODEL=claude-sonnet-4-5
CLAUDE_TIMEOUT_SECONDS=300

# Doubao (火山方舟) provider - 仅当 LLM_PROVIDER=doubao 时生效
# API key 在 https://console.volcengine.com/ark 拿；只填这一行就能跑
DOUBAO_API_KEY=
# 下面这些都有默认值，想换公共模型或换自建 endpoint id 时再覆盖
# DOUBAO_MODEL=doubao-1-5-vision-pro-32k-250115
# DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# DOUBAO_TIMEOUT_SECONDS=120

# Agent SDK (v2 路径 /api/v2/analyze) - 不受 LLM_PROVIDER 开关影响
# v2 固定走 claude-agent-sdk + 本地 Claude CLI 订阅；不需要单独 API key
# 模型不要用 sonnet alias（同 v1 教训）
AGENT_MODEL=claude-opus-4-7
# smoke 实测单图 ~250s（Read image → 场景识别 → load_scenario × N → 思考 → submit）；
# 默认放到 360s 留余地，单测用 fake 时显式覆盖为短超时
AGENT_TIMEOUT_SECONDS=360
# Agent 最大 tool 调用回合数；防死循环
AGENT_MAX_TURNS=15
# Skill 库根目录（zip 解压位置）；默认 = 仓库根/safety_skills
# SAFETY_SKILLS_ROOT=safety_skills

# Storage
SQLITE_PATH=local_data/safety_scout.db
UPLOAD_DIR=uploads

# Image upload
MAX_IMAGE_MB=15

# Async polling
POLL_INTERVAL_MS=2000
TIMEOUT_MS=330000

# Backend
BACKEND_HARD_TIMEOUT_S=320
RATE_LIMIT_PER_MINUTE=10
